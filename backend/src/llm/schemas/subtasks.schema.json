{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "subtasks": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "ord":   { "type": "integer", "minimum": 1 }
        },
        "required": ["title", "ord"],
        "additionalProperties": false
      }
    }
  },
  "required": ["subtasks"],
  "additionalProperties": false
}
