{
  "name": "infertask",
  "version": "0.1.0",
  "description": "Lokale To-Do App mit integriertem LLM — Inferenz trifft Task Management.",
  "type": "commonjs",
  "scripts": {
    "dev:backend": "ts-node --esm backend/src/server.ts",
    "build:backend": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "test": "echo \"Tests folgen in Phase 2 (Vitest)\" && exit 0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mick-gsk/InferTask.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/mick-gsk/InferTask/issues"
  },
  "homepage": "https://mick-gsk.github.io/InferTask/",
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^25.8.0",
    "ts-node": "^10.9.2"
  }
}
