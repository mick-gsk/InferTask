{
  "name": "infertask",
  "version": "0.1.0",
  "description": "Local-first To-Do App mit integriertem lokalem LLM",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint frontend/src/**/*.ts",
    "lint:fix": "eslint frontend/src/**/*.ts --fix",
    "format": "prettier --write \"frontend/**/*.{ts,css,html}\"",
    "format:check": "prettier --check \"frontend/**/*.{ts,css,html}\"",
    "check": "npm run typecheck && npm run lint && npm run format:check"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0"
  }
}
